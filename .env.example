# SecondBrain Configuration

# Ollama Settings
OLLAMA_URL=http://localhost:11434
MODEL_NAME=mistral
EMBED_MODEL=nomic-embed-text

# Whisper Settings
WHISPER_MODEL=base

# Server Settings
HOST=0.0.0.0
PORT=8000
DEFAULT_RECORD_SECONDS=10

# CORS Settings (comma-separated origins, * for all)
ALLOW_CORS=*

# Storage Paths (relative to project root)
VECTOR_DB_PATH=data/vector_db/index.faiss
VECTOR_META_PATH=data/vector_db/meta.pkl
VOICE_DB_PATH=data/voices.pkl

# Privacy Settings
PRIVACY_MODE=false

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=int16

# Processing Settings
MAX_AUDIO_CHUNK_SIZE=30
SILENCE_THRESHOLD=0.01
MIN_TRANSCRIPTION_LENGTH=5

# Memory Settings
MAX_MEMORY_RESULTS=100
MEMORY_IMPORTANCE_THRESHOLD=0.6

# UI Settings
THEME=dark
AUTO_REFRESH_INTERVAL=30
